pkgname=mygpiod
_pkgname=myGPIOd
pkgver=1.1.0
pkgrel=1
pkgdesc="lightweight gpio controlling daemon"
arch=('x86_64' 'armv7h' 'aarch64')
url="https://jcorporation.github.io/myGPIOd/"
license=('GPL')
depends=('libmicrohttpd' 'libmpdclient' 'curl' 'lua' 'libgpiod')
makedepends=('cmake' 'gzip')
optdepends=()
provides=()
conflicts=()
replaces=()
backup=('etc/mygpiod.conf')
install=archlinux.install
source=("mygpiod-${pkgver}.tar.gz")
sha256sums=('SKIP')
options=(debug strip)

build() {
  local cmake_options=(
    -B build
    -S "${srcdir}/${pkgname}-${pkgver}"
    -DCMAKE_BUILD_TYPE=RelWithDebInfo
    -DCMAKE_INSTALL_PREFIX=/usr
    -Wno-dev
  )

  cmake "${cmake_options[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
