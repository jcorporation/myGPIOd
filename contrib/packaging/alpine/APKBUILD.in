pkgname=mygpiod
pkgver=__VERSION__
pkgrel=0
pkgdesc="Lightweight gpio controlling daemon"
url="https://jcorporation.github.io/myGPIOd/"
arch="all"
license="GPL-3.0-or-later"
depends=""
makedepends="cmake
	curl-dev
	libmpdclient-dev
	lua5.4-dev
	samurai
	"
install="$pkgname.pre-install $pkgname.post-install"
source="mygpiod_$pkgver.orig.tar.gz"
builddir="$srcdir"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-doc"
options="!check"
#no test suite

build() {
	cmake -B "$builddir/release" -DCMAKE_INSTALL_PREFIX:PATH=/usr -DCMAKE_BUILD_TYPE=RelWithDebInfo "$builddir"
	cmake --build "$builddir/release"
}

package() {
	DESTDIR="$pkgdir" cmake --install "$builddir/release"
}
